{
    "blank_line_after_tag": "extends,include,import",
    "blank_line_before_tag": "block,extends",
    "close_void_tags": true,
    "extend_exclude": ".cache,build,coverage,dist,node_modules,out,release",
    "extension": "html,jinja,jinja2,j2",
    "indent": 4,
    "line_break_after_multiline_tag": true,
    "linter_output_format": "{filename}:{line}: {code} {message} {match}",
    "max_attribute_length": 0,
    "max_blank_lines": 2,
    "max_line_length": 120,
    "preserve_blank_lines": true,
    "profile": "jinja",
    "use_gitignore": true
}
